{
  "manifest_version": 3,
  "name": "LoLé",
  "version": "1.0",
  "icons": {
    "16": "./resources/logo_16.png",
    "32": "./resources/logo_32.png",
    "128": "./resources/logo_128.png"
  },
  "description": "Logiciel offering 4 Logitech Ecosystemé",
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "js": [
        "src/pages.js",
        "src/content.js"
      ],
      "matches": [
        "<all_urls>"
      ],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "permissions": [
    "tabs",
    "windows",
    "storage",
    "identity",
    "tabGroups",
    "scripting",
    "contextMenus",
    "notifications",
    "webNavigation",
    "identity.email",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/aid.js",
        "resources/Comfortaa.ttf",
        "resources/scroll-up.png",
        "resources/scroll-down.png",
        "resources/logo_128.png",
        "resources/logi_products/*.webp",
        "resources/Nunito-VariableFont_wght.ttf"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "commands": {
    "capture_screen": {
      "suggested_key": {
        "default": "Ctrl+Shift+Z",
        "mac": "Command+Shift+Z"
      },
      "description": "Capture screen"
    },
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Space",
        "mac": "Command+Shift+Space"
      }
    }
  }
}